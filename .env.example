# === Production: скопируйте в .env и заполните ===
# Файл .env должен лежать в КОРНЕ проекта (рядом с docker-compose.yml и .env.example).
# При запуске через Docker Compose переменные подхватываются из этого файла автоматически.
# При локальном запуске сервера (pnpm run dev:server) .env загружается из корня проекта.

# Пин-код для входа на сайт (опционально). Если задан — без ввода пин-кода доступ к приложению закрыт.
# После 5 неверных попыток с одного IP доступ блокируется на 15 минут.
# SITE_PIN=1234

# Порт приложения. По умолчанию 3000; для прода можно задать другой (например 8080).
# PORT=8080

# PostgreSQL — для раздела «История проверок» и «Расписания». Без него приложение работает без истории.
# Обычный формат: postgresql://user:password@host:5432/dbname
# Selectel (SSL): ...?sslmode=require или ...?sslmode=verify-ca (для verify-ca см. ниже).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Для verify-ca (Selectel и др.): путь к CA-сертификату (в Docker — путь внутри контейнера, например /app/certs/selectel-ca.pem).
# DATABASE_SSL_CA_PATH=/app/certs/selectel-ca.pem

# Telegram — уведомления при срабатывании расписания (нарушения, блокировки, ошибки).
# Бот: @BotFather → токен. Chat ID: @userinfobot.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=860003314

# Публичный URL приложения (для ссылки «Открыть отчёт» в Telegram). Обязательно для продакшена с уведомлениями.
# BASE_URL=https://mon.your-domain.com
